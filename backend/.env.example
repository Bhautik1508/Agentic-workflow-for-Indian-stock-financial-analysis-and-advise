# Backend Environment Variables
# Copy this to .env for local dev. Set these directly in Render dashboard for production.

# === LLM APIs ===
GROQ_API_KEY=                    # https://console.groq.com/keys
GOOGLE_API_KEY=                  # https://aistudio.google.com/app/apikey

# === News APIs ===
NEWS_API_KEY=                    # https://newsapi.org/account
MARKETAUX_API_KEY=               # https://www.marketaux.com/account/dashboard
ALPHA_VANTAGE_KEY=               # https://www.alphavantage.co/support/#api-key

# === CORS (Production) ===
# Comma-separated list of allowed frontend origins. Set in Render dashboard after Vercel deploy.
# Example: https://your-app.vercel.app
ALLOWED_ORIGINS=

# === Optional: Redis Cache (Upstash) ===
# Leave blank to use local file-based cache instead
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# === Optional: Supabase ===
# Leave blank if not using
SUPABASE_URL=
SUPABASE_KEY=

